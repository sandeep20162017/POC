function cancelRbPartPopup(e) {

    console.warn("Cancel clicked in RbParts popup...");

    var wnd = $("#RbPartsPopupWindow").data("kendoWindow");

    if (wnd) {
        wnd.close();   // Clean close
    }

    // Re-select the correct tab (optional but safe)
    var tabStrip = $("#rebuiltTabStrip").data("kendoTabStrip");
    if (tabStrip) {
        tabStrip.select(1); // adjust index if needed
    }

    // Force grid rebind ONLY inside the tab
    var grid = $("#RebuiltGrid").data("kendoGrid");
    if (grid) {
        grid.dataSource.read();
    }
}
