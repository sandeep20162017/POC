success: function (response) {

    if (response) {

        pendingChanges = false;

        var win = $("#estimatePopup").data("kendoWindow");

        // 🔥 Replace popup content with fresh DB HTML
        win.content(response);

        // 🔥 Re-read ID from hidden field inside new content
        var newId = $("#RebuiltId").val();

        window.currentRebuiltId = newId;

        // Refresh grid
        $("#RebuiltGrid").data("kendoGrid").dataSource.read();

        // Update window title
        win.title("Rebuilt Parts Estimate #" + newId);

        kendo.alert("Estimate #: " + newId + " Saved successfully!");

    } else {
        kendo.alert("Save succeeded but no Estimate ID was returned.");
    }
}
