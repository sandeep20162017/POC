In the following script, variable  @RebuiltStockNum  is passed by front end, as string
It should be inserted in SBCES.RbListOfBuses
Fix pls
--MBListOfBuses
 @RebuiltStockNum as varchar = '12345'
INSERT INTO SBCES.RbListOfBuses
(
    RebuiltStockNum,
    ListId
)
SELECT
    @RebuiltStockNum,
    MBLB.ListId           AS ListId
FROM
    SBCES.MbListOfBuses AS MBLB
INNER JOIN
    SBCES.ListOfBuses AS LOB
        ON LOB.ListId = MBLB.ListId
WHERE
    MBLB.MbNumber = 'MBH0097' --@MbNumber;

