CREATE PROCEDURE SBCES.GetLabourCost
(
    @IdNum VARCHAR(50),
    @Type VARCHAR(50),
    @FinalPrice DECIMAL(20,2) OUTPUT
)
AS
BEGIN
    SET NOCOUNT ON;

    TRUNCATE TABLE SBCES.TempLabourList;

    ---------------------------------------------------------
    -- Load labour for this part
    ---------------------------------------------------------
    EXEC SBCES.WriteLabour @IdNum, 1.0;

    ---------------------------------------------------------
    -- Return total cost
    ---------------------------------------------------------
    SELECT @FinalPrice = ROUND(SUM(TotalCost), 2)
    FROM SBCES.TempLabourList;
END
GO
