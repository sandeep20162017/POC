Step 1 — Create a Global Variable

At the top of Index.cshtml:

<script>
    var currentMbNumber = null;
</script>
🔥 Step 2 — Save It When You Receive It

Where you currently have:

win.title("Make Vs Buy Estimate #" + response.MbNumber);

Modify it to:

currentMbNumber = response.MbNumber;

win.title("Make Vs Buy Estimate #" + currentMbNumber);

Now the value is stored safely for the whole page lifecycle.

✅ Step 3 — Use It Inside onTabSelect

Now modify your tab handler:

window.onTabSelect = function (e) {

    var index = $(e.item).index();

    var tabsConfig = [
        { id: "makevsbuyTabContent", url: '@Url.Action("GetMakeVsBuyById", "MakeVsBuy")' },
        { id: "partsTabContent", url: "/MakeVsBuy/MaterialCostSummaryPartial" },
        { id: "labourTabContent", url: "/MakeVsBuy/LabourHourSummaryPartial" },
        { id: "allLabourTabContent", url: "/MakeVsBuy/AllLabourInRBPartial" },
        { id: "labourDetailsTabContent", url: "/MakeVsBuy/LabourDetailsPartial" },
        { id: "stockCodedPartsTabContent", url: "/MakeVsBuy/ScDetailsPartial" },
        { id: "nonStockCodedPartsTabContent", url: "/MakeVsBuy/NonStockPartsPartial" },
        { id: "rebuiltPartsTabContent", url: "/MakeVsBuy/RebuiltPartsPartial" },
        { id: "finalEstimateTabContent", url: "/MakeVsBuy/TotalCostPartial" }
    ];

    var selectedTab = tabsConfig[index];

    if (!selectedTab || !currentMbNumber)
        return;

    $("#" + selectedTab.id).load(
        selectedTab.url,
        { id: currentMbNumber }
    );
};

✔ Now every tab receives id = response.MbNumber
