.Columns(c =>
{
    c.Bound(v => v.MbNumber)
     .Title("Mb Number #")
     .Filterable(f => f.Cell(cell =>
     {
         cell.Operator("contains");
         cell.ShowOperators(false);
     }))
     .ClientTemplate(
        "<a class='estimate-link' onclick=\"window.openEstimatePopup('#= MbNumber #')\">#= MbNumber #</a>")
     .Width(60);
});
