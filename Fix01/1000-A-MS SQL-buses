DECLARE @RebuiltStockNum VARCHAR(30) = '12345';
DECLARE @MbNumber VARCHAR(30) = 'MBH0097';
2. Insert using INSERT…SELECT
sql
INSERT INTO SBCES.RbListOfBuses
(
    RebuiltStockNum,
    ListId
)
SELECT
    @RebuiltStockNum,
    MBLB.ListId
FROM
    SBCES.MbListOfBuses AS MBLB
INNER JOIN
    SBCES.ListOfBuses AS LOB
        ON LOB.ListId = MBLB.ListId
WHERE
    MBLB.MbNumber = @MbNumber;
