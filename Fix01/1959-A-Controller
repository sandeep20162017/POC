private async Task<IEnumerable<LabourDetailsRebuiltPartsViewModel>> GetAllLabourDetails(
    string partNum, 
    string gridType)
{
    try
    {
        var parameters = new DynamicParameters();
        parameters.Add("@IdNum", partNum);
        parameters.Add("@Type", gridType);

        // Stored proc returns full TempLabourList result set
        var result = await _DbConnection.QueryAsync<LabourDetailsRebuiltPartsViewModel>(
            "SBCES.GetLabourCost",
            parameters,
            commandType: CommandType.StoredProcedure
        );

        return result;
    }
    catch (Exception ex)
    {
        // Log exception if needed
        throw;
    }
}
