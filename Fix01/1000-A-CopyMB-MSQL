INSERT INTO SBCES.MbList
(
    MbNumber,
    Keyword,
    Description,
    BusType,
    NumBusComp,
    VendorPartNum,
    BuyCode,
    RebuildCode,
    CoreCode,
    AnnualUsage,
    BenchNumber,
    SampleProvided,
    Recommendation,
    RemanCost,
    ExternalCost,
    BuyNewCost,
    InternalCost,
    SopNumber,
    CoreCost,
    JobNumber,
    DateOpened,
    ReadManualNewPrice
)
SELECT
    ISNULL(@NewMbNumber, ' ')                     AS MbNumber,
    UPPER(ISNULL(@Keyword, ' '))                  AS Keyword,
    ML.Description,
    ML.BusType,
    ML.NumBusComp,
    ML.VendorPartNum,
    ML.BuyCode,
    UPPER(ISNULL(@RebuildNumber, ' '))            AS RebuildCode,
    ML.CoreCode,
    ML.AnnualUsage,
    ML.BenchNumber,
    ML.SampleProvided,
    ML.Recommendation,
    ML.RemanCost,
    ML.ExternalCost,
    ML.BuyNewCost,
    ML.InternalCost,
    ML.SopNumber,
    ML.CoreCost,
    ML.JobNumber,
    GETDATE()                                     AS DateOpened,
    ML.ReadManualNewPrice
FROM
    SBCES.MbList AS ML
WHERE
    ML.MbNumber = @MbNumber;
