private async Task<RebuiltPartsViewModel> GetRebuiltPartById(int id)
{
    var sql = @"
        SELECT 
            RebuiltId,
            RebuiltStockNum,
            MmsStockCode,
            DetailedDesc AS Description,
            Keyword AS KeyWord,
            JobNumber,
            CoreCharge,
            CorePartNum,
            BuyNewCost,
            RemanCost,
            LastModifiedBy,
            DateEntered,
            LastModifiedDate
        FROM SBCES.RbMasterlist
        WHERE RebuiltId = @Id";

    return await _dbConnection.QueryFirstOrDefaultAsync<RebuiltPartsViewModel>(
        sql,
        new { Id = id });
}
