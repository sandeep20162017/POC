function onStockCodedPartEdit(e) {

    setTimeout(function () {

        var popup = $(".k-window.scparts-popup-style");

        var top =
            (($(window).height() - popup.outerHeight()) / 2) - 50;

        popup.css({
            left: "50%",
            top: Math.max(10, top) + "px"
        });

        popup.css(
            "margin-left",
            -(popup.outerWidth() / 2) + "px"
        );

    }, 50);

}
