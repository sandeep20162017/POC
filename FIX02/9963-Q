   function cancelScPartPopup() {
      console.warn("Cancel clicked in ScParts popup...");

      // Try to find the nearest active Kendo window
      var wndElement = $("#ScPartsPopupWindow");
      var wnd = wndElement.data("kendoWindow");

      if (!wnd) {
          // fallback: maybe the Cancel button is inside the popup form template
          wndElement = $(event.target).closest(".k-window-content");
          wnd = wndElement.data("kendoWindow");
      }

      if (wnd) {
          //  Simulate clicking the built-in X button
          wnd.wrapper.find(".k-window-action .k-i-close").trigger("click");
      } else {
          console.warn("No Kendo window found for RbParts popup.");
      }
}


