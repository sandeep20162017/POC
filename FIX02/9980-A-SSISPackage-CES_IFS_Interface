2.3 Interface status table + proc (success/failure flag)
sql
USE [CES];
GO

IF OBJECT_ID('[SBCES].[InterfaceStatus]', 'U') IS NOT NULL
    DROP TABLE [SBCES].[InterfaceStatus];
GO

CREATE TABLE [SBCES].[InterfaceStatus] (
    InterfaceName    VARCHAR(100) NOT NULL,
    LastRunDateTime  DATETIME     NULL,
    LastStatus       VARCHAR(20)  NULL,   -- e.g. SUCCESS / FAIL
    LastErrorDesc    VARCHAR(2000) NULL,
    CONSTRAINT PK_InterfaceStatus PRIMARY KEY (InterfaceName)
);
GO

IF OBJECT_ID('[SBCES].[usp_SetInterfaceStatus]', 'P') IS NOT NULL
    DROP PROCEDURE [SBCES].[usp_SetInterfaceStatus];
GO

CREATE PROCEDURE [SBCES].[usp_SetInterfaceStatus]
    @InterfaceName VARCHAR(100),
    @Status        VARCHAR(20),
    @ErrorDesc     VARCHAR(2000) = NULL
AS
BEGIN
    SET NOCOUNT ON;

    IF EXISTS (SELECT 1 FROM [SBCES].[InterfaceStatus] WHERE InterfaceName = @InterfaceName)
    BEGIN
        UPDATE [SBCES].[InterfaceStatus]
        SET LastRunDateTime = GETDATE(),
            LastStatus      = @Status,
            LastErrorDesc   = @ErrorDesc
        WHERE InterfaceName = @InterfaceName;
    END
    ELSE
    BEGIN
        INSERT INTO [SBCES].[InterfaceStatus] (
            InterfaceName,
            LastRunDateTime,
            LastStatus,
            LastErrorDesc
        )
        VALUES (
            @InterfaceName,
            GETDATE(),
            @Status,
            @ErrorDesc
        );
    END
END;
GO
We’ll use InterfaceName = 'CES_IFS' in SSIS.

