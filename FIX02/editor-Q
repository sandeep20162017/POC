@model BCES.Models.Admin.EditorModel
@using Kendo.Mvc.UI

@{
    ViewData["Title"] = "HTML Editor";
}

<h6>Announcements</h6>

@using (Html.BeginForm("SaveContent", "Content", FormMethod.Post))
{
    <div class="form-group">
        @* Remove explicit Name() when using EditorFor *@
        @(Html.Kendo().EditorFor(m => m.Content)
            .Tools(tools => tools
            .Clear()
            .Bold().Italic().Underline()
            .CreateLink().Unlink()
            .InsertImage()
            .TableEditing()
            .ViewHtml()
            .FontName()
            .FontSize()
            )
            .HtmlAttributes(new { style = "height:300px" })
           
            )
    </div>

    <button type="submit" class="k-button k-primary">Save Content</button>
}
