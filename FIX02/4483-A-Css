/* Stock Coded Parts Popup */
.scparts-popup-style {
    background: #fff;
    padding: 12px 16px;
}

/* Toolbar */
.scparts-popup-style .popup-actions {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
    margin-bottom: 12px;
    padding-bottom: 10px;
    border-bottom: 1px solid #e5e5e5;
}

/* Form layout */
.scparts-popup-style .form-container {
    width: 100%;
}

.scparts-popup-style .form-row {
    display: flex;
    gap: 12px;
    margin-bottom: 10px;
}

.scparts-popup-style .form-group {
    flex: 1;
}

.scparts-popup-style .double-width {
    flex: 2;
}

.scparts-popup-style .full-width {
    width: 100%;
}

/* Section headers */
.scparts-popup-style .section-title {
    font-weight: 600;
    font-size: 13px;
    margin: 14px 0 10px;
    padding-bottom: 4px;
    border-bottom: 1px solid #d9d9d9;
}

/* Labels */
.scparts-popup-style .form-label {
    display: block;
    font-weight: 600;
    margin-bottom: 4px;
}

/* Telerik controls */
.scparts-popup-style .k-textbox,
.scparts-popup-style .k-combobox,
.scparts-popup-style .k-dropdown,
.scparts-popup-style .k-numerictextbox {
    width: 100% !important;
}

/* readonly fields */
.scparts-popup-style input[readonly] {
    background-color: #f8f8f8;
}

/* Total Cost emphasis */
.scparts-popup-style #TotalCost {
    font-weight: 600;
}

/* remove unnecessary whitespace */
.scparts-popup-style .k-edit-form-container {
    padding: 0;
}
