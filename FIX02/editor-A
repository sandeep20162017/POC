@model BCES.Models.Admin.EditorModel
@using Kendo.Mvc.UI

@{
    ViewData["Title"] = "HTML Editor";
}

<h6>Announcements</h6>

@using (Html.BeginForm("SaveContent", "Content", FormMethod.Post))
{
    <div class="form-group">

        @(Html.Kendo().EditorFor(m => m.Content)
            .Tools(tools => tools
                // Text formatting
                .Clear()
                .Bold()
                .Italic()
                .Underline()
                .Strikethrough()

                // Fonts
                .FontName()
                .FontSize()
                .ForeColor()
                .BackColor()

                // Alignment
                .JustifyLeft()
                .JustifyCenter()
                .JustifyRight()
                .JustifyFull()

                // Lists
                .InsertUnorderedList()
                .InsertOrderedList()

                // Links & media
                .CreateLink()
                .Unlink()
                .InsertImage()

                // Tables
                .TableEditing()

                // View
                .ViewHtml()
            )
            .HtmlAttributes(new { style = "height:300px" })
        )

    </div>

    <button type="submit" class="k-button k-primary">Save Content</button>
}
