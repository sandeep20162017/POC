CREATE OR ALTER PROCEDURE SBCES.RptCostVariance
AS
BEGIN

    SET NOCOUNT ON;

    ------------------------------------------------------------------
    -- Populate TempRbpCost
    ------------------------------------------------------------------

    EXEC SBCES.InternalRbPrice;

    ------------------------------------------------------------------
    -- Return Result Set
    ------------------------------------------------------------------

    SELECT *
    FROM SBCES.TempRbpCost
    ORDER BY RbNumber;

END
GO
