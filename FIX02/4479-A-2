@{
    ViewData["Title"] = "Total Cost Summary";
    string gridName = $"LabourDetailsGrid_{ViewBag.PartNum}";
}

<!DOCTYPE html>
<html>
<head>
    <title>Total Cost Summary Report</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
        /* Print Styles */
        @@media print {
            body {
                background: white;
                margin: 0;
                padding: 0.25in;
            }
            .no-print {
                display: none !important;
            }
            .report-container {
                box-shadow: none;
                padding: 0;
                margin: 0;
            }
            .cost-table {
                break-inside: avoid;
                page-break-inside: avoid;
            }
            .print-button {
                display: none;
            }
            .section-title {
                break-after: avoid;
            }
        }

        /* Screen Styles */
        * {
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', 'Roboto', Arial, sans-serif;
            background: #eef2f5;
            margin: 0;
            padding: 20px;
        }

        .report-container {
            max-width: 1100px;
            margin: 0 auto;
            background: white;
            border-radius: 8px;
            box-shadow: 0 2px 15px rgba(0,0,0,0.1);
            padding: 25px 30px 35px 30px;
        }

        .report-header {
            text-align: center;
            margin-bottom: 25px;
            padding-bottom: 15px;
            border-bottom: 3px solid #2c3e50;
        }

        .report-header h1 {
            margin: 0 0 8px 0;
            color: #1a5276;
            font-size: 26px;
            letter-spacing: 1px;
        }

        .report-header .subtitle {
            color: #5d6d7e;
            font-size: 13px;
            font-family: monospace;
        }

        /* Section Titles */
        .section-title {
            font-size: 18px;
            font-weight: bold;
            background-color: #2c3e50;
            color: white;
            padding: 10px 15px;
            margin: 25px 0 15px 0;
            border-radius: 4px;
            letter-spacing: 0.5px;
        }

        /* Table-like structure for cost rows */
        .cost-table {
            width: 100%;
            margin-bottom: 5px;
            border-collapse: collapse;
        }

        .cost-table td {
            padding: 10px 8px;
            vertical-align: middle;
        }

        .label-cell {
            font-weight: 700;
            color: #2c3e50;
            width: 180px;
            background-color: #f8f9fa;
            border-bottom: 1px solid #e9ecef;
        }

        .value-cell {
            font-weight: 500;
            color: #1a5276;
            border-bottom: 1px solid #e9ecef;
        }

        .total-value-cell {
            font-weight: 800;
            color: #1a5276;
            font-size: 1.05em;
            border-bottom: 1px solid #e9ecef;
        }

        /* Divider rows */
        .divider-row td {
            border-top: 2px solid #cbd5e1;
            padding-top: 12px;
        }

        .subtotal-row .label-cell {
            font-weight: 800;
            background-color: #e8f0fe;
        }

        .subtotal-row .value-cell {
            font-weight: 800;
            font-size: 1.02em;
        }

        /* Grand Total styling */
        .grand-total-row .label-cell {
            font-weight: 800;
            font-size: 1.1em;
            background-color: #d4e6f1;
            color: #0b3b5f;
            border-top: 2px solid #2c3e50;
            border-bottom: 2px solid #2c3e50;
        }

        .grand-total-row .total-value-cell {
            font-weight: 800;
            font-size: 1.2em;
            background-color: #d4e6f1;
            color: #0b3b5f;
            border-top: 2px solid #2c3e50;
            border-bottom: 2px solid #2c3e50;
        }

        /* Material row groupings */
        .material-breakdown-row .label-cell {
            background-color: #ffffff;
            padding-left: 25px;
        }

        /* Print button */
        .print-button {
            background-color: #2c3e50;
            color: white;
            border: none;
            padding: 10px 24px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 20px;
            float: right;
            transition: background 0.2s;
        }

        .print-button:hover {
            background-color: #1a5276;
        }

        .clearfix::after {
            content: "";
            clear: both;
            display: table;
        }

        /* Loading & no data */
        .loading-spinner {
            text-align: center;
            padding: 60px;
            color: #5d6d7e;
            font-size: 16px;
        }

        .no-data-message {
            text-align: center;
            padding: 50px;
            background: #fef9e6;
            border-radius: 8px;
        }

        .warning-icon {
            font-size: 48px;
            margin-bottom: 10px;
        }

        .retry-btn {
            background-color: #2c3e50;
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 4px;
            margin-top: 15px;
            cursor: pointer;
        }
    </style>
</head>
<body>

<div class="report-container">
    <div class="clearfix">
        <button class="print-button no-print" onclick="window.print();">🖨️ Print Report</button>
    </div>

    <div class="report-header">
        <h1>TOTAL COST SUMMARY REPORT</h1>
        <div class="subtitle">Estimate ID: @ViewBag.PartNum &nbsp;|&nbsp; Generated: @DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss")</div>
    </div>

    <!-- Loading Indicator -->
    <div id="loadingIndicator" class="loading-spinner">
        <span>⏳ Loading cost data...</span>
    </div>

    <!-- Cost Summary Content - Professional Report Layout -->
    <div id="costSummaryContent" style="display: none;">
        
        <!-- ==================== SECTION: MATERIAL COST ==================== -->
        <div class="section-title">📦 MATERIAL COST</div>
        
        <table class="cost-table" id="materialCostTable">
            <!-- Row 1: Parts Total = SC Parts + NSC Parts + RB Cost = Total Cost (no Tax) -->
            <tr>
                <td class="label-cell"><strong>Parts Total:</strong></td>
                <td class="value-cell" id="partsTotalDisplay">$0.00</td>
                <td class="label-cell"><strong>SC Parts:</strong></td>
                <td class="value-cell" id="scPartsDisplay">$0.00</td>
            </tr>
            <tr>
                <td class="label-cell"><strong>NSC Parts:</strong></td>
                <td class="value-cell" id="nscPartsDisplay">$0.00</td>
                <td class="label-cell"><strong>RB Cost:</strong></td>
                <td class="value-cell" id="rbCostDisplay">$0.00</td>
            </tr>
            <tr class="subtotal-row">
                <td class="label-cell"><strong>Total Material Cost (no Tax):</strong></td>
                <td class="total-value-cell" id="materialNoTaxDisplay">$0.00</td>
                <td></td>
                <td></td>
            </tr>
            
            <!-- Row 2: Tax and Total with Tax -->
            <tr>
                <td class="label-cell"><strong>Tax Amount:</strong></td>
                <td class="value-cell" id="materialTaxDisplay">$0.00</td>
                <td class="label-cell"><strong>Total Material Cost (with Tax):</strong></td>
                <td class="total-value-cell" id="materialWithTaxDisplay">$0.00</td>
            </tr>
        </table>

        <!-- ==================== SECTION: LABOUR COST ==================== -->
        <div class="section-title">🔧 LABOUR COST</div>
        
        <table class="cost-table" id="labourCostTable">
            <tr>
                <td class="label-cell"><strong>Fringe:</strong></td>
                <td class="value-cell" id="labourFringeDisplay">$0.00</td>
                <td class="label-cell"><strong>Benefits:</strong></td>
                <td class="value-cell" id="labourBenefitsDisplay">$0.00</td>
            </tr>
            <tr>
                <td class="label-cell"><strong>Blended Fringe & Benefits:</strong></td>
                <td class="value-cell" id="blendedFringeCostDisplay">$0.00</td>
                <td class="label-cell"><strong>Overhead:</strong></td>
                <td class="value-cell" id="labourOverheadDisplay">$0.00</td>
            </tr>
            <tr class="subtotal-row">
                <td class="label-cell"><strong>Total Labour Cost:</strong></td>
                <td class="total-value-cell" id="totalLabourCostDisplay">$0.00</td>
                <td></td>
                <td></td>
            </tr>
        </table>

        <!-- ==================== SECTION: TOTAL COST ==================== -->
        <div class="section-title">💰 TOTAL COST SUMMARY</div>
        
        <table class="cost-table" id="totalCostTable">
            <tr>
                <td class="label-cell"><strong>Total Material Cost (with Tax):</strong></td>
                <td class="value-cell" id="totalMaterialWithTaxDisplay">$0.00</td>
                <td class="label-cell"><strong>Total Labour Cost:</strong></td>
                <td class="value-cell" id="totalLabourCostDisplay2">$0.00</td>
            </tr>
            <tr class="grand-total-row">
                <td class="label-cell"><strong>GRAND TOTAL (with Tax):</strong></td>
                <td class="total-value-cell" id="totalWithTaxDisplay">$0.00</td>
                <td></td>
                <td></td>
            </tr>
        </table>
        
        <!-- Additional breakdown note for clarity -->
        <div style="margin-top: 20px; padding: 10px; background: #f8f9fa; font-size: 12px; color: #5d6d7e; text-align: center; border-radius: 4px;">
            * This report includes all applicable taxes and fees
        </div>
    </div>

    <!-- No data message -->
    <div id="noDataMessage" class="no-data-message" style="display: none;">
        <div class="warning-icon">⚠️</div>
        <p style="font-size: 16px; margin: 10px 0;"><strong>No cost data available</strong></p>
        <p>No cost data found for Estimate ID: @ViewBag.PartNum</p>
        <button id="retryButton" class="retry-btn">⟳ Retry Loading</button>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    // Store parameters from ViewBag
    var partNum = '@ViewBag.PartNum';
    var gridType = '@ViewBag.GridType';

    // Build URL with proper parameter encoding
    var totalCostDataUrl = '@Url.Action("GetTotalCostInEstimates", "TotalCost")' +
                           '?id=' + encodeURIComponent(partNum) +
                           '&gridType=' + encodeURIComponent(gridType);

    $(document).ready(function() {
        fetchTotalCostData();
        $("#retryButton").click(function() {
            $("#noDataMessage").hide();
            $("#loadingIndicator").show();
            $("#costSummaryContent").hide();
            fetchTotalCostData();
        });
    });

    function fetchTotalCostData() {
        console.log("Fetching data from:", totalCostDataUrl);
        
        $.ajax({
            url: totalCostDataUrl,
            type: 'GET',
            dataType: 'json',
            timeout: 30000,
            success: function(response) {
                console.log("Response received:", response);
                
                if (response && response.Data && response.Data.length > 0) {
                    var costData = response.Data[0];
                    console.log("Cost data:", costData);
                    populateCostSummary(costData);
                    $("#loadingIndicator").hide();
                    $("#costSummaryContent").show();
                    $("#noDataMessage").hide();
                } else {
                    console.log("No data in response");
                    showNoDataMessage();
                }
            },
            error: function(xhr, status, error) {
                console.error("Error fetching cost data:", status, error);
                console.error("Response text:", xhr.responseText);
                showNoDataMessage();
            }
        });
    }

    function populateCostSummary(costData) {
        // Helper to get numeric values
        function getVal(value) {
            if (value === null || value === undefined) return 0;
            var num = parseFloat(value);
            return isNaN(num) ? 0 : num;
        }

        // Format currency
        function formatMoney(val) {
            return '$' + val.toLocaleString(undefined, { 
                minimumFractionDigits: 2, 
                maximumFractionDigits: 2 
            });
        }

        // Helper to set text
        function setText(id, value) {
            $(id).text(formatMoney(value));
        }

        // Extract values from costData
        var scParts = getVal(costData.SCPartsMaterialCost);
        var nscParts = getVal(costData.NSCSCPartsMaterialCost);
        var rbParts = getVal(costData.RBPartsMaterialCost);
        var materialNoTax = getVal(costData.MaterialTotalCostNoTax);
        var materialTax = getVal(costData.MaterialTotalTaxAmount);
        var materialWithTax = getVal(costData.MaterialTotalWithTax);
        
        var labourFringe = getVal(costData.LabourFringe);
        var labourBenefits = getVal(costData.LabourBenefits);
        var blendedFringeCost = getVal(costData.BlendedFringeBenefitCost);
        var labourOverhead = getVal(costData.LabourOverhead);
        var totalLabour = getVal(costData.FinalLabourCost);
        var totalWithTax = getVal(costData.TotalWithTax);

        // Populate Material Section
        setText("#scPartsDisplay", scParts);
        setText("#nscPartsDisplay", nscParts);
        setText("#rbCostDisplay", rbParts);
        setText("#partsTotalDisplay", materialNoTax);
        setText("#materialNoTaxDisplay", materialNoTax);
        setText("#materialTaxDisplay", materialTax);
        setText("#materialWithTaxDisplay", materialWithTax);

        // Populate Labour Section
        setText("#labourFringeDisplay", labourFringe);
        setText("#labourBenefitsDisplay", labourBenefits);
        setText("#blendedFringeCostDisplay", blendedFringeCost);
        setText("#labourOverheadDisplay", labourOverhead);
        setText("#totalLabourCostDisplay", totalLabour);

        // Populate Total Section
        setText("#totalMaterialWithTaxDisplay", materialWithTax);
        setText("#totalLabourCostDisplay2", totalLabour);
        setText("#totalWithTaxDisplay", totalWithTax);
        
        // Verify totals are correct
        console.log("Material Total (no tax):", materialNoTax);
        console.log("Material Tax:", materialTax);
        console.log("Material Total (with tax):", materialWithTax);
        console.log("Labour Total:", totalLabour);
        console.log("Grand Total:", totalWithTax);
    }

    function showNoDataMessage() {
        $("#loadingIndicator").hide();
        $("#costSummaryContent").hide();
        $("#noDataMessage").show();
    }
</script>

</body>
</html>
