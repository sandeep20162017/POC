function saveScPartPopup() {

    console.warn("Saving SC Parts...");

    var model = currentScPartsModel;

    if (model) {

        // ✔ FORCE SYNC FINAL VALUES FROM UI TO MODEL
        var qty = $("input[name='Qty']").data("kendoNumericTextBox");
        var percentage = $("input[name='Percentage']").data("kendoNumericTextBox");
        var totalCost = $("input[name='TotalCost']").data("kendoNumericTextBox");

        if (qty) model.set("Qty", qty.value());
        if (percentage) model.set("Percentage", percentage.value());
        if (totalCost) model.set("TotalCost", totalCost.value());

        // ✔ FIX: set Modified fields from ViewBag.UserName
        model.set("LastModifiedBy", window.currentUserName || '@ViewBag.UserName');
        model.set("LastModifiedDate", new Date());
    }

    var formData = $("#scPartsForm").serialize();

    $.ajax({
        url: '/YourController/UpdateScPartsUsedInEstimates',
        type: 'POST',
        data: formData,

        success: function (result) {

            console.warn("Save successful");

            var grid = $("[id^='ScPartsMaterialDetailsRebuiltPartsGrid_']")
                .data("kendoGrid");

            if (grid) {
                grid.dataSource.read();
            }

            cancelScPartPopup();
        },

        error: function (xhr) {
            console.error("Save failed:", xhr.responseText);
            alert("Error saving record");
        }
    });
}
