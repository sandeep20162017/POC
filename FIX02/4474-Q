Telerik .NETcore grid
LabourHrs and LabourMins are int in model
UI displays LabourMins as 02.00 and LabourHrs as 33.00 (as decimal) - default

<div class="form-group  double-width">
    @Html.LabelFor(m => m.LabourHrs, "Labour Hrs", new { @class = "form-label required-label" })
    @(Html.Kendo().NumericTextBoxFor(m => m.LabourHrs).Min(0).Max(132).HtmlAttributes(new { required = "required" }))
</div>
<div class="form-group  double-width">
    @Html.LabelFor(m => m.LabourMins, "Labour Mins", new { @class = "form-label required-label" })
    @(Html.Kendo().NumericTextBoxFor(m => m.LabourMins).Min(0).Max(59).HtmlAttributes(new { required = "required" }))
</div>
