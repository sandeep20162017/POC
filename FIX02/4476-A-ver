SELECT
      [OldId],
      [ArchVehicleListId],
      [VehSeriesCode],
      [NumOfVehicles],
      [ProjDesc],
      [DateEntered],
      [EnteredBy],
      [Make],
      [Model],
      [Year],
      [Engine],
      [Transmission],
      [Differential],
      [LabourCost],
      [LabourOverheadAmount],
      [LabourTotal],
      [MaterialsTotal],
      [TotalBusEstimateCost],
      [TotalTax],
      [TotalCostTax],
      [OemKitsTotal],
      [Sopnumber],

      ROW_NUMBER() OVER (
            PARTITION BY OldId
            ORDER BY DateEntered ASC
      ) AS VersionAsc

FROM [CES].[SBCES].[ArchVehicleList]
ORDER BY OldId DESC, ArchVehicleListId DESC;
