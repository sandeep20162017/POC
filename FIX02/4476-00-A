@{
    // Detect if this is a Create scenario:
    // ModelState has no entry for Percentage → user has not posted yet → Create mode
    bool isCreate = !ViewData.ModelState.ContainsKey("Percentage");
}

@(Html.Kendo().NumericTextBoxFor(m => m.Percentage)
    .Format("n0")
    .Min(0)
    .Max(100)
    .Value(isCreate ? 100 : Model.Percentage)
    .HtmlAttributes(new { required = "required" })
)
