.popup-action {
    display: flex;
    gap: 10px;
    align-items: center;
}

#btnHelpMakeVsBuy {
    margin-left: auto;
}

<div class="popup-action">
    <button id="btnSaveMakeVsBuy" class="k-button k-primary" type="button">
        Update
    </button>

    <button id="btnCancelMakeVsBuy" class="k-button" type="button">
        Cancel
    </button>

    <button id="btnHelpMakeVsBuy"
            class="k-button k-button-icontext"
            type="button"
            onclick="showHelpPopup('/help/makevsbuypopuphelp.html')">

        <span class="k-icon k-i-question"></span>
        Help
    </button>
</div>
