begin
update KITS_MASTERLIST SET ESTIMATED_COST = (SELECT MMS_NEW_COST FROM STOCK_CODED_PARTS WHERE STOCK_CODED_PARTS.MMS_STOCK_CODE = KITS_MASTERLIST.part_number) where EXISTS (SELECT MMS_NEW_COST FROM STOCK_CODED_PARTS WHERE rtrim(STOCK_CODED_PARTS.MMS_STOCK_CODE) = rtrim(KITS_MASTERLIST.part_number));
     commit;
    EXCEPTION
    WHEN OTHERS THEN RAISE;
        err_num := SQLCODE;
        err_msg := SUBSTR(SQLERRM, 1, 100);
