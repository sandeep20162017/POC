create or replace PROCEDURE ifs_mms_sync IS

V_LINK_CODE VARCHAR(30);
--V_LINK_CODE NUMBER;
V_PRICE number (15,5); --hold temperary dollar amounts trhoughout the function
err_num NUMBER; --holds the error number if an error should occur
err_msg VARCHAR2(100);  --holds teh error message should an error occur


--Creates a cursor with a list of rebuilt part #'s entered in the application
CURSOR C_RB_LIST
    IS
    SELECT upper(rtrim(rebuilt_stock_num))
    from RB_MasterList;

-- Creates a cursor of all the stock coded parts used in all the estimates,
-- exludes stock codes which represent rebuilt parts
CURSOR C_SC_PARTS_LIST
    IS
    SELECT distinct mms_stock_code
    from sc_parts_used
    where rebuilt_part = 'N';

-- Start MMSSYNC
begin

begin
EXECUTE IMMEDIATE 'TRUNCATE TABLE STOCK_CODED_PARTS_BACKUP';
end;

begin
insert into STOCK_CODED_PARTS_BACKUP ( MMS_STOCK_CODE , CORE_PART_NUMBER , PART_TYPE , JOB_NUMBER , DETAILED_DESC
      , DATE_ENTERED , ITEM_REF_NUMBER , OVERHEADTYPE , CORE_CHARGE , PART_COST
      , LAST_MODIFIED_DATE , LAST_MODIFIED_BY , ADDED_BY , MMS_NEW_COST , OEM_PART_COST
      , MMS_SYNC_DATE, ORIG_SUPPLIER_NUM, ORIG_SUPPLIER_NAME ) select
      trim(nvl(mms_stock_code,' ')), nvl(core_part_number,' '), nvl(part_type,' '), nvl(job_number,' '),
       nvl(detailed_desc,' '), nvl(date_entered,' ') , nvl(item_ref_number,' '), nvl(overheadtype,0),
       nvl(core_charge,0), nvl(part_cost,0),last_modified_date, last_modified_by,
       nvl(added_by,' '), nvl(mms_new_cost,0), nvl(oem_part_cost,0), mms_sync_date,
       nvl(orig_supplier_num,' '), nvl(orig_supplier_name,' ')
      from STOCK_CODED_PARTS;
      commit;
    EXCEPTION
    WHEN OTHERS THEN RAISE;
        err_num := SQLCODE;
        err_msg := SUBSTR(SQLERRM, 1, 100);
        dbms_output.put_line('ERROR: insert into STOCK_CODED_PARTS_BACKUP');
        raise_application_error(err_num, err_msg , FALSE);
        rollback;
end;

begin
EXECUTE IMMEDIATE 'truncate TABLE STOCK_CODED_PARTS';
end;

begin
EXECUTE IMMEDIATE 'truncate TABLE PRICENOTAX';
end;

begin
EXECUTE IMMEDIATE 'truncate TABLE LASTPRICENOTAX';
end;
