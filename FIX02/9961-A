<div class="form-row">
    <div class="form-group double-width">

        @Html.LabelFor(m => m.Recommendation, "Recommendation", new { @class = "form-label" })

        @(Html.Kendo().DropDownListFor(m => m.Recommendation)
            .DataTextField("Text")
            .DataValueField("Value")
            .BindTo(new List<SelectListItem>
            {
                new SelectListItem { Text = "Make In House", Value = "1" },
                new SelectListItem { Text = "Buy New", Value = "2" },
                new SelectListItem { Text = "In Progress", Value = "3" }
            })
            .Value(
                string.IsNullOrEmpty(Model?.Recommendation)
                    ? "1"
                    : Model.Recommendation
            )
            .Enable(isNew)
        )

    </div>
</div>
