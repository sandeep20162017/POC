@{
    ViewData["Title"] = "Total Cost Summary";
    string gridName = $"LabourDetailsGrid_{ViewBag.PartNum}";
}

<!DOCTYPE html>
<html>
<head>
    <title>Total Cost Summary Report</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
        /* Print Styles - FIXED for full page printing */
        @@media print {
            /* Reset body for printing */
            body {
                background: white;
                margin: 0 !important;
                padding: 0 !important;
                height: auto !important;
                overflow: visible !important;
            }
            
            /* Hide print button and other non-print elements */
            .no-print {
                display: none !important;
            }
            
            /* Main container - ensure full content prints */
            .report-container {
                box-shadow: none;
                padding: 0.2in;
                margin: 0;
                max-width: 100% !important;
                overflow: visible !important;
                height: auto !important;
            }
            
            /* Ensure side-by-side layout prints correctly */
            .side-by-side {
                display: flex !important;
                gap: 20px;
                page-break-inside: avoid;
                break-inside: avoid;
                overflow: visible !important;
            }
            
            /* Individual sections */
            .material-section, .labour-section {
                break-inside: avoid;
                page-break-inside: avoid;
                overflow: visible !important;
            }
            
            /* Tables - ensure they don't get cut off */
            .info-table {
                break-inside: avoid;
                page-break-inside: avoid;
                width: 100%;
            }
            
            /* Grand total section */
            .grand-total-section {
                break-inside: avoid;
                page-break-inside: avoid;
                margin-top: 20px;
            }
            
            /* Totals row */
            .totals-row {
                display: flex !important;
                gap: 20px;
                break-inside: avoid;
                page-break-inside: avoid;
            }
            
            /* Force full height printing */
            html, body {
                height: auto !important;
                overflow: visible !important;
            }
            
            /* Remove any scrollbar-related styles */
            ::-webkit-scrollbar {
                display: none;
            }
            
            /* Ensure all content is visible */
            .report-footer {
                margin-top: 20px;
                break-inside: avoid;
            }
        }

        /* Screen Styles */
        * {
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', 'Roboto', Arial, sans-serif;
            background: #eef2f5;
            margin: 0;
            padding: 20px;
            overflow-y: auto; /* Allow scrolling on screen */
        }

        .report-container {
            max-width: 1400px;
            margin: 0 auto;
            background: white;
            border-radius: 8px;
            box-shadow: 0 2px 15px rgba(0,0,0,0.1);
            padding: 25px 30px 35px 30px;
        }

        .report-header {
            text-align: center;
            margin-bottom: 25px;
            padding-bottom: 15px;
            border-bottom: 3px solid #2c3e50;
        }

        .report-header h1 {
            margin: 0 0 8px 0;
            color: #1a5276;
            font-size: 28px;
            letter-spacing: 1px;
        }

        .report-header .subtitle {
            color: #5d6d7e;
            font-size: 13px;
            font-family: monospace;
        }

        /* Side by Side Layout */
        .side-by-side {
            display: flex;
            gap: 30px;
            margin-bottom: 30px;
            flex-wrap: wrap;
        }

        /* Material Section (Left) */
        .material-section {
            flex: 1;
            min-width: 350px;
            background: #ffffff;
            border: 2px solid #2c3e50;
            border-radius: 8px;
            overflow: hidden;
        }

        .material-header {
            background-color: #2c3e50;
            color: white;
            padding: 14px 20px;
            font-size: 18px;
            font-weight: bold;
            text-align: center;
            letter-spacing: 1px;
        }

        .material-body {
            padding: 20px;
        }

        /* Labour Section (Right) */
        .labour-section {
            flex: 1;
            min-width: 350px;
            background: #ffffff;
            border: 2px solid #2c3e50;
            border-radius: 8px;
            overflow: hidden;
        }

        .labour-header {
            background-color: #2c3e50;
            color: white;
            padding: 14px 20px;
            font-size: 18px;
            font-weight: bold;
            text-align: center;
            letter-spacing: 1px;
        }

        .labour-body {
            padding: 20px;
        }

        /* Table styles */
        .info-table {
            width: 100%;
            border-collapse: collapse;
        }

        .info-table tr {
            border-bottom: 1px solid #e0e4e8;
        }

        .info-table tr:last-child {
            border-bottom: none;
        }

        .info-table td {
            padding: 12px 8px;
            vertical-align: middle;
        }

        .label-col {
            font-weight: 600;
            color: #2c3e50;
            width: 55%;
        }

        .value-col {
            font-weight: 500;
            color: #1a5276;
            text-align: right;
            width: 45%;
        }

        .total-row td {
            padding-top: 15px;
            border-top: 2px solid #cbd5e1;
        }

        .total-row .label-col {
            font-weight: 800;
            font-size: 1.05em;
            color: #0b3b5f;
        }

        .total-row .value-col {
            font-weight: 800;
            font-size: 1.05em;
            color: #0b3b5f;
        }

        .tax-row .label-col {
            color: #e67e22;
        }

        .tax-row .value-col {
            color: #e67e22;
            font-weight: 600;
        }

        .empty-row td {
            padding: 12px 8px;
            border-bottom: 1px solid #e0e4e8;
        }
        
        .empty-row .label-col {
            color: transparent;
        }
        
        .empty-row .value-col {
            color: transparent;
        }

        /* Grand Total Section */
        .grand-total-section {
            margin-top: 20px;
            background: #f8f9fa;
            border-radius: 8px;
            border: 2px solid #1a5276;
        }

        .grand-total-table {
            width: 100%;
            border-collapse: collapse;
        }

        .grand-total-table td {
            padding: 18px 25px;
        }

        .grand-total-label {
            font-weight: 800;
            font-size: 1.2em;
            color: #1a5276;
            background-color: #e8f0fe;
        }

        .grand-total-value {
            font-weight: 800;
            font-size: 1.3em;
            color: #1a5276;
            text-align: right;
            background-color: #e8f0fe;
        }

        /* Totals Row (Material and Labour totals on same line) */
        .totals-row {
            display: flex;
            gap: 30px;
            margin: 20px 0;
            flex-wrap: wrap;
        }

        .total-box {
            flex: 1;
            background: #e8f0fe;
            border: 1px solid #cbd5e1;
            border-radius: 8px;
            padding: 15px 20px;
            text-align: center;
        }

        .total-box-label {
            font-weight: 700;
            font-size: 1em;
            color: #2c3e50;
            margin-bottom: 8px;
        }

        .total-box-value {
            font-weight: 800;
            font-size: 1.3em;
            color: #1a5276;
        }

        /* Print button */
        .print-button {
            background-color: #2c3e50;
            color: white;
            border: none;
            padding: 10px 24px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 20px;
            float: right;
            transition: background 0.2s;
        }

        .print-button:hover {
            background-color: #1a5276;
        }

        .clearfix::after {
            content: "";
            clear: both;
            display: table;
        }

        /* Loading & no data */
        .loading-spinner {
            text-align: center;
            padding: 60px;
            color: #5d6d7e;
            font-size: 16px;
        }

        .no-data-message {
            text-align: center;
            padding: 50px;
            background: #fef9e6;
            border-radius: 8px;
        }

        .warning-icon {
            font-size: 48px;
            margin-bottom: 10px;
        }

        .retry-btn {
            background-color: #2c3e50;
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 4px;
            margin-top: 15px;
            cursor: pointer;
        }

        .report-footer {
            margin-top: 25px;
            padding: 10px;
            background: #f8f9fa;
            font-size: 11px;
            color: #5d6d7e;
            text-align: center;
            border-radius: 4px;
            border-top: 1px solid #dee2e6;
        }
    </style>
</head>
<body>

<div class="report-container">
    <div class="clearfix">
        <button class="print-button no-print" onclick="printFullPage();">🖨️ Print Full Report</button>
    </div>

    <div class="report-header">
        <h1>TOTAL COST SUMMARY REPORT</h1>
        <div class="subtitle">Estimate ID: @ViewBag.PartNum</div>
    </div>

    <!-- Loading Indicator -->
    <div id="loadingIndicator" class="loading-spinner">
        <span>⏳ Loading cost data...</span>
    </div>

    <!-- Cost Summary Content - Side by Side -->
    <div id="costSummaryContent" style="display: none;">
        
        <!-- SIDE BY SIDE: Material Cost (6 rows) | Labour Cost (6 rows with empty first row) -->
        <div class="side-by-side">
            
            <!-- LEFT: MATERIAL COST (6 rows) -->
            <div class="material-section">
                <div class="material-header">📦 MATERIAL COST</div>
                <div class="material-body">
                    <table class="info-table">
                        <!-- Row 1: Stock Coded Parts -->
                        <tr>
                            <td class="label-col"><strong>Stock Coded Parts</strong></td>
                            <td class="value-col" id="scPartsDisplay">$0.00</td>
                        </tr>
                        <!-- Row 2: Non-Stock Coded Parts -->
                        <tr>
                            <td class="label-col"><strong>Non-Stock Coded Parts</strong></td>
                            <td class="value-col" id="nscPartsDisplay">$0.00</td>
                        </tr>
                        <!-- Row 3: Rebuilt Parts -->
                        <tr>
                            <td class="label-col"><strong>Rebuilt Parts</strong></td>
                            <td class="value-col" id="rbCostDisplay">$0.00</td>
                        </tr>
                        <!-- Row 4: Parts Total (No Tax) -->
                        <tr class="total-row">
                            <td class="label-col"><strong>Parts Total (No Tax)</strong></td>
                            <td class="value-col" id="partsTotalDisplay">$0.00</td>
                        </tr>
                        <!-- Row 5: Material Tax -->
                        <tr class="tax-row">
                            <td class="label-col"><strong>+ Material Tax</strong></td>
                            <td class="value-col" id="materialTaxDisplay">$0.00</td>
                        </tr>
                        <!-- Row 6: Total Material Cost (With Tax) -->
                        <tr class="total-row">
                            <td class="label-col"><strong>= Total Material Cost (With Tax)</strong></td>
                            <td class="value-col" id="materialWithTaxDisplay">$0.00</td>
                        </tr>
                    </table>
                </div>
            </div>

            <!-- RIGHT: LABOUR COST (6 rows with empty first row) -->
            <div class="labour-section">
                <div class="labour-header">🔧 LABOUR COST</div>
                <div class="labour-body">
                    <table class="info-table">
                        <!-- Row 1: EMPTY ROW (to align with Material's first row) -->
                        <tr class="empty-row">
                            <td class="label-col">&nbsp;</td>
                            <td class="value-col">&nbsp;</td>
                        </tr>
                        <!-- Row 2: Fringe -->
                        <tr>
                            <td class="label-col"><strong>Fringe</strong></td>
                            <td class="value-col" id="labourFringeDisplay">$0.00</td>
                        </tr>
                        <!-- Row 3: Benefits -->
                        <tr>
                            <td class="label-col"><strong>Benefits</strong></td>
                            <td class="value-col" id="labourBenefitsDisplay">$0.00</td>
                        </tr>
                        <!-- Row 4: Blended Fringe & Benefits -->
                        <tr>
                            <td class="label-col"><strong>Blended Fringe & Benefits</strong></td>
                            <td class="value-col" id="blendedFringeCostDisplay">$0.00</td>
                        </tr>
                        <!-- Row 5: Overhead -->
                        <tr>
                            <td class="label-col"><strong>Overhead</strong></td>
                            <td class="value-col" id="labourOverheadDisplay">$0.00</td>
                        </tr>
                        <!-- Row 6: Total Labour Cost -->
                        <tr class="total-row">
                            <td class="label-col"><strong>= Total Labour Cost</strong></td>
                            <td class="value-col" id="totalLabourCostDisplay">$0.00</td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <!-- TOTALS ROW: Material Total and Labour Total on Same Row -->
        <div class="totals-row">
            <div class="total-box">
                <div class="total-box-label">TOTAL MATERIAL COST (With Tax)</div>
                <div class="total-box-value" id="totalMaterialBoxDisplay">$0.00</div>
            </div>
            <div class="total-box">
                <div class="total-box-label">TOTAL LABOUR COST</div>
                <div class="total-box-value" id="totalLabourBoxDisplay">$0.00</div>
            </div>
        </div>

        <!-- GRAND TOTAL SECTION -->
        <div class="grand-total-section">
            <table class="grand-total-table">
                <tr>
                    <td class="grand-total-label"><strong>💰 GRAND TOTAL (Material + Labour)</strong></td>
                    <td class="grand-total-value" id="totalWithTaxDisplay">$0.00</td>
                </tr>
            </table>
        </div>

        <!-- Footer Note -->
        <div class="report-footer">
            Estimate Printed On: @DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss")
        </div>
    </div>

    <!-- No data message -->
    <div id="noDataMessage" class="no-data-message" style="display: none;">
        <div class="warning-icon">⚠️</div>
        <p style="font-size: 16px; margin: 10px 0;"><strong>No cost data available</strong></p>
        <p>No cost data found for Estimate ID: @ViewBag.PartNum</p>
        <button id="retryButton" class="retry-btn">⟳ Retry Loading</button>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    // Store parameters from ViewBag
    var partNum = '@ViewBag.PartNum';
    var gridType = '@ViewBag.GridType';

    // Build URL with proper parameter encoding
    var totalCostDataUrl = '@Url.Action("GetTotalCostInEstimates", "TotalCost")' +
                           '?id=' + encodeURIComponent(partNum) +
                           '&gridType=' + encodeURIComponent(gridType);

    $(document).ready(function() {
        fetchTotalCostData();
        $("#retryButton").click(function() {
            $("#noDataMessage").hide();
            $("#loadingIndicator").show();
            $("#costSummaryContent").hide();
            fetchTotalCostData();
        });
    });

    // Enhanced print function to ensure full page prints
    function printFullPage() {
        // Store original title
        var originalTitle = document.title;
        
        // Optional: Add a small delay to ensure all content is rendered
        setTimeout(function() {
            window.print();
        }, 100);
    }

    function fetchTotalCostData() {
        console.log("Fetching data from:", totalCostDataUrl);
        
        $.ajax({
            url: totalCostDataUrl,
            type: 'GET',
            dataType: 'json',
            timeout: 30000,
            success: function(response) {
                console.log("Response received:", response);
                
                if (response && response.Data && response.Data.length > 0) {
                    var costData = response.Data[0];
                    console.log("Cost data:", costData);
                    populateCostSummary(costData);
                    $("#loadingIndicator").hide();
                    $("#costSummaryContent").show();
                    $("#noDataMessage").hide();
                } else {
                    console.log("No data in response");
                    showNoDataMessage();
                }
            },
            error: function(xhr, status, error) {
                console.error("Error fetching cost data:", status, error);
                showNoDataMessage();
            }
        });
    }

    function populateCostSummary(costData) {
        // Helper to get numeric values
        function getVal(value) {
            if (value === null || value === undefined) return 0;
            var num = parseFloat(value);
            return isNaN(num) ? 0 : num;
        }

        // Format currency
        function formatMoney(val) {
            return '$' + val.toLocaleString(undefined, { 
                minimumFractionDigits: 2, 
                maximumFractionDigits: 2 
            });
        }

        // Helper to set text
        function setText(id, value) {
            $(id).text(formatMoney(value));
        }

        // Extract values from costData
        var scParts = getVal(costData.SCPartsMaterialCost);
        var nscParts = getVal(costData.NSCSCPartsMaterialCost);
        var rbParts = getVal(costData.RBPartsMaterialCost);
        var partsTotalNoTax = getVal(costData.MaterialTotalCostNoTax);
        var materialTax = getVal(costData.MaterialTotalTaxAmount);
        var materialWithTax = getVal(costData.MaterialTotalWithTax);
        
        // Labour values
        var labourFringe = getVal(costData.LabourFringe);
        var labourBenefits = getVal(costData.LabourBenefits);
        var blendedFringeCost = getVal(costData.BlendedFringeBenefitCost);
        var labourOverhead = getVal(costData.LabourOverhead);
        var totalLabour = getVal(costData.FinalLabourCost);
        
        // Grand total
        var totalWithTax = getVal(costData.TotalWithTax);

        // Populate Material Section (Left - 6 rows)
        setText("#scPartsDisplay", scParts);
        setText("#nscPartsDisplay", nscParts);
        setText("#rbCostDisplay", rbParts);
        setText("#partsTotalDisplay", partsTotalNoTax);
        setText("#materialTaxDisplay", materialTax);
        setText("#materialWithTaxDisplay", materialWithTax);

        // Populate Labour Section (Right - 5 rows + 1 empty row)
        setText("#labourFringeDisplay", labourFringe);
        setText("#labourBenefitsDisplay", labourBenefits);
        setText("#blendedFringeCostDisplay", blendedFringeCost);
        setText("#labourOverheadDisplay", labourOverhead);
        setText("#totalLabourCostDisplay", totalLabour);

        // Populate Totals Row (Side by Side)
        setText("#totalMaterialBoxDisplay", materialWithTax);
        setText("#totalLabourBoxDisplay", totalLabour);

        // Populate Grand Total
        setText("#totalWithTaxDisplay", totalWithTax);
        
        // Console log for verification
        console.log("=== COST SUMMARY VERIFICATION ===");
        console.log("MATERIAL (6 rows):");
        console.log("  Row 1 - Stock Coded Parts:", scParts);
        console.log("  Row 2 - Non-Stock Coded Parts:", nscParts);
        console.log("  Row 3 - Rebuilt Parts:", rbParts);
        console.log("  Row 4 - Parts Total (no tax):", partsTotalNoTax);
        console.log("  Row 5 - Material Tax:", materialTax);
        console.log("  Row 6 - Material Total (with tax):", materialWithTax);
        console.log("LABOUR (6 rows with empty first row):");
        console.log("  Row 1 - EMPTY");
        console.log("  Row 2 - Fringe:", labourFringe);
        console.log("  Row 3 - Benefits:", labourBenefits);
        console.log("  Row 4 - Blended Fringe & Benefits:", blendedFringeCost);
        console.log("  Row 5 - Overhead:", labourOverhead);
        console.log("  Row 6 - Total Labour:", totalLabour);
        console.log("GRAND TOTAL (with tax):", totalWithTax);
    }

    function showNoDataMessage() {
        $("#loadingIndicator").hide();
        $("#costSummaryContent").hide();
        $("#noDataMessage").show();
    }
</script>

</body>
</html>
