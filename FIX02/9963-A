function saveScPartPopup() {

    console.warn("Saving SC Part popup...");

    // Update Modified By immediately in popup UI
    var modifiedBy = $("input[name='LastModifiedBy']")
        .data("kendoTextBox");

    if (modifiedBy) {
        modifiedBy.value(window.currentUserName);
    }

    // Update Modified Date immediately in popup UI
    var modifiedDate = $("input[name='LastModifiedDate']")
        .data("kendoTextBox");

    var now = new Date();

    if (modifiedDate) {

        modifiedDate.value(
            kendo.toString(now, "yyyy-MM-dd HH:mm:ss")
        );
    }

    // Serialize form
    var formData = $("#scPartsForm").serialize();

    $.ajax({
        url: '/YourController/UpdateScPartsUsedInEstimates',
        type: 'POST',
        data: formData,

        success: function (result) {

            console.warn("SC Part saved successfully.");

            // IMPORTANT:
            // Refresh Telerik Grid datasource so popup reopens with fresh values
            var grid = $("[id^='ScPartsMaterialDetailsRebuiltPartsGrid_']")
                .data("kendoGrid");

            if (grid) {
                grid.dataSource.read();
            }

            // Close popup
            cancelScPartPopup();
        },

        error: function (xhr) {

            console.error("Error saving SC Part:", xhr.responseText);

            alert("Error saving record.");
        }
    });
}
