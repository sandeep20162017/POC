3. Add this Javascript

Place near the bottom of _TotalCost.cshtml:

$(function () {

    /////////////////////////////////////////////
    // Context menu
    /////////////////////////////////////////////

    $("#reportMenu").kendoContextMenu({

        target: "#reportActions",

        showOn: "mouseenter",

        alignToAnchor: true,

        select: function (e) {

            var id = $(e.item).attr("id");

            if (id === "saveReport") {

                saveReportAsPng();

            }

            if (id === "copyReport") {

                copyReportToClipboard();

            }
        }

    });

});
4. Save PNG
function saveReportAsPng() {

    kendo.drawing.drawDOM($("#costSummaryContent"), {

        paperSize: "auto",
        margin: "1cm",
        scale: 1

    })
    .then(function (group) {

        return kendo.drawing.exportImage(group);

    })
    .done(function (data) {

        kendo.saveAs({

            dataURI: data,
            fileName: "TotalCostSummary.png"

        });

    });

}
5. Copy image to clipboard
function copyReportToClipboard() {

    kendo.drawing.drawDOM($("#costSummaryContent"), {

        paperSize: "auto",
        margin: "1cm",
        scale: 1

    })
    .then(function (group) {

        return kendo.drawing.exportImage(group);

    })
    .done(function (data) {

        fetch(data)
            .then(res => res.blob())
            .then(blob => {

                navigator.clipboard.write([

                    new ClipboardItem({
                        "image/png": blob
                    })

                ]);

                kendo.alert("Report copied to clipboard.");

            });

    });

}
Optional (nicer UX)

Instead of opening on hover, I would recommend a small ⋮ icon button:

       ⋮
    ┌─────────────────────┐
    │ 📋 Copy to Clipboard│
    │ 🖼 Save as PNG      │
    └─────────────────────┘

using:

showOn: "click"

Hover menus tend to disappear accidentally and are harder to use. A click-triggered menu behaves more like Outlook, Visual Studio, and Windows Explorer and feels more polished.

