// AUTO-CALCULATE TOTAL COST WITH DEBUG
$(document).on("change",
    "input[name='Qty'], input[name='UnitCost'], input[name='Percentage']",
    function () {

        console.warn("=== TOTAL COST CALCULATION TRIGGERED ===");

        var popup = $(".k-window-content:visible");
        console.warn("Popup found:", popup.length > 0);

        // RAW INPUTS
        console.warn("Raw Qty input:", popup.find("input[name='Qty']")[0]);
        console.warn("Raw UnitCost input:", popup.find("input[name='UnitCost']")[0]);
        console.warn("Raw Percentage input:", popup.find("input[name='Percentage']")[0]);

        // GET WIDGETS
        var qtyWidget = popup.find("input[name='Qty']").data("kendoNumericTextBox");
        var unitCostWidget = popup.find("input[name='UnitCost']").data("kendoNumericTextBox");
        var percentageWidget = popup.find("input[name='Percentage']").data("kendoNumericTextBox");

        console.warn("qtyWidget:", qtyWidget);
        console.warn("unitCostWidget:", unitCostWidget);
        console.warn("percentageWidget:", percentageWidget);

        if (!qtyWidget || !unitCostWidget || !percentageWidget) {
            console.error("❌ Widgets not found");
            return;
        }

        // VALUES
        var qty = qtyWidget.value() || 0;
        var unitCost = unitCostWidget.value() || 0;
        var percentage = percentageWidget.value() || 0;

        console.warn("Extracted values → qty:", qty, "unitCost:", unitCost, "percentage:", percentage);

        var total = qty * unitCost * (percentage / 100);

        console.warn("CALCULATION →", qty, "×", unitCost, "×", (percentage / 100), "=", total);

        // GET GRID NAME
        var gridName = $("#nscGridNameField").val();
        console.warn("Grid name:", gridName);

        var parentGrid = $("#" + gridName).data("kendoGrid");

        // GET POPUP MODEL
        var model = parentGrid?.editable?.options?.model;

        console.warn("Model BEFORE update:", model);

        if (model) {

            // SYNC MODEL FIRST
            model.set("Qty", qty);
            model.set("UnitCost", unitCost);
            model.set("Percentage", percentage);

            model.set("TotalCost", total);

            console.warn("Model AFTER update:", model.toJSON());

        } else {
            console.error("❌ Model not found");
        }

        // UPDATE TOTAL COST WIDGET
        var totalCostWidget = popup.find("input[name='TotalCost']").data("kendoNumericTextBox");

        console.warn("totalCostWidget:", totalCostWidget);

        if (totalCostWidget) {
            totalCostWidget.value(total);
            totalCostWidget.trigger("change");
            console.warn("TotalCost widget updated →", total);
        }

        // ================================
        // FIX: UPDATE PARENT GRID ROW
        // ================================

        if (parentGrid && model) {

            console.warn("Updating parent grid row...");

            var dataItem = parentGrid.dataSource.get(model.OrigSuppNum);

            console.warn("DataItem:", dataItem);

            if (dataItem) {

                dataItem.set("TotalCost", total);

                console.warn("DataItem TotalCost updated →", total);

                parentGrid.refresh();

                console.warn("Parent grid refreshed");

            } else {
                console.warn("❌ Could not find datasource item by OrigSuppNum");
            }
        }

        console.warn("=== END TOTAL COST CALCULATION ===");
    }
);
